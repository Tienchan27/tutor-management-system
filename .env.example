# Copy to .env and fill in real values. Do not commit .env.

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Default admin (Flyway seed on first migrate)
# Email used for the seeded admin account; password is the plaintext for the bcrypt hash below.
DEFAULT_ADMIN_EMAIL=admin@example.com
# BCrypt hash (generate with your preferred tool; example plaintext: Admin@123)
DEFAULT_ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# JWT (at least 32 bytes for HS256)
JWT_SECRET=replace-with-a-long-random-secret

# Postgres (local host port 5433 when using compose postgres-db)
POSTGRES_DB=tms_db
DATABASE_URL=jdbc:postgresql://localhost:5433/tms_db
DATABASE_USERNAME=tms_user
DATABASE_PASSWORD=replace-me

# Server
SERVER_PORT=8081
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Mail (Mailpit in Docker)
MAIL_HOST=localhost
MAIL_PORT=1025

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka / realtime (optional toggles)
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REALTIME_ENABLED=true

# Student tuition invoices (Asia/Ho_Chi_Minh)
STUDENT_INVOICE_AUTO_DAY=1
STUDENT_INVOICE_DUE_DAYS=15
